<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.sisinf.estante.controller.PanelInfoTablaController"
      spacing="8"
      VBox.vgrow="ALWAYS">

    <padding>
        <Insets top="8" right="8" bottom="8" left="8"/>
    </padding>

    <Label fx:id="labelNombreTabla"
           text="Selecciona una tabla"
           style="-fx-font-weight: bold;"/>

    <TableView fx:id="tablaColumnas" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNombre"  text="Nombre"   prefWidth="120"/>
            <TableColumn fx:id="colTipo"    text="Tipo"     prefWidth="100"/>
            <TableColumn fx:id="colNullable" text="Nullable" prefWidth="80"/>
            <TableColumn fx:id="colDefault" text="Default"  prefWidth="120"/>
        </columns>
    </TableView>

</VBox>